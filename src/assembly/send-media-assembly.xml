<assembly xmlns="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.3">
    <id>send-media-impl</id>
    <formats><format>zip</format></formats>
    <includeBaseDirectory>false</includeBaseDirectory>
    <fileSets>
        <fileSet>
            <directory>${project.build.outputDirectory}</directory>
            <outputDirectory>/</outputDirectory>
            <includes><include>whatsapp-send-media.*</include><include>*.png</include></includes>
        </fileSet>
    </fileSets>
    <dependencySets>
        <dependencySet><outputDirectory>classpath</outputDirectory><useProjectArtifact>true</useProjectArtifact><scope>provided</scope></dependencySet>
    </dependencySets>
</assembly>
